{
  "expo": {
    "name": "Mentora",
    "slug": "mentora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "android": {
      "usesCleartextTraffic": false,
      "permissions": [
        "ACTIVITY_RECOGNITION",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C9E87"
      },
      "package": "com.mentora.app"
    },
    "ios": {
      "bundleIdentifier": "com.mentora.app",
      "infoPlist": {
        "NSMotionUsageDescription": "Mentora uses motion activity to track your daily step count.",
        "NSUserNotificationsUsageDescription": "Mentora uses notifications for medication, wellness, sleep, and daily reminder alerts."
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C9E87",
          "defaultChannel": "reminders"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://mentora-mental-health-and-fitness-app.onrender.com",
      "eas": {
        "projectId": "86edf528-115d-4d0b-aeb5-ec7e7048ec66"
      }
    }
  }
}
